{
  "name": "torqena",
  "version": "0.0.26",
  "private": true,
  "description": "Torqena is an AI-powered desktop application for knowledge management, built with Electron, Vite, and the GitHub Copilot CLI SDK.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:shell": "npm run dev:shell -w @torqena/desktop",
    "dev:electron": "npm run dev:electron -w @torqena/desktop",
    "build:shell": "npm run build:shell -w @torqena/desktop",
    "build:electron": "npm run build:electron -w @torqena/desktop",
    "lint": "eslint .",
    "test": "npm run test -w @torqena/desktop",
    "test:watch": "npm run test:watch -w @torqena/desktop",
    "test:coverage": "npm run test:coverage -w @torqena/desktop",
    "electron": "npm run electron -w @torqena/desktop"
  },
  "keywords": [
    "copilot",
    "ai",
    "github",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.39.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1",
    "globals": "14.0.0"
  }
}
