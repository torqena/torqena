<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary brand colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3B1F99</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#1A1A2E</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    <Color x:Key="Accent">#7C4DFF</Color>

    <!-- Neutral palette -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray50">#F9FAFB</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>

    <!-- Semantic colors -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>

    <!-- Surface colors (light) -->
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceVariantLight">#F3F4F6</Color>
    <Color x:Key="BackgroundLight">#F9FAFB</Color>
    <Color x:Key="TextPrimaryLight">#111827</Color>
    <Color x:Key="TextSecondaryLight">#6B7280</Color>
    <Color x:Key="BorderLight">#E5E7EB</Color>

    <!-- Surface colors (dark) -->
    <Color x:Key="SurfaceDark">#1E1E2E</Color>
    <Color x:Key="SurfaceVariantDark">#2A2A3E</Color>
    <Color x:Key="BackgroundDark">#11111B</Color>
    <Color x:Key="TextPrimaryDark">#CDD6F4</Color>
    <Color x:Key="TextSecondaryDark">#A6ADC8</Color>
    <Color x:Key="BorderDark">#313244</Color>

</ResourceDictionary>
